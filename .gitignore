!/public/robots.txt

# Generated code coverage output
/coverage
/tests/coverage
/tests/coverage-xml
/tests/coverage.xml

# Other generated files
/opspilot_test
/.env.example.bak

# Vite build output
/public/build/

# Runtime storage — contents are ephemeral; inner .gitignore placeholders preserve directories
/storage/app/public/*
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
!/storage/**/.gitignore

# Empty docs directories (keep gitignore for structure)
docs/analysis/
docs/proposals/

.env.testing

