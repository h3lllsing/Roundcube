APP_NAME="OpsPilot"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
ASSET_URL=
ALLOW_REGISTRATION=false

DEMO_ENTITY_PASSWORD=
L5_SWAGGER_CONST_HOST="${APP_URL}"
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
# APP_TIMEZONE=UTC
# APP_PAGINATION_PER_PAGE=20

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# APP_VERSION=1.0.0
# APP_PREVIOUS_KEYS=
# BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# LOG_DEPRECATIONS_TRACE=false
LOG_LEVEL=warning
# LOG_DAILY_DAYS=14
# LOG_SLACK_WEBHOOK_URL=
# LOG_SLACK_USERNAME=
# LOG_SLACK_EMOJI=:boom:
# PAPERTRAIL_URL=
# PAPERTRAIL_PORT=
# LOG_SYSLOG_FACILITY=LOG_USER
# LOG_STDERR_FORMATTER=
# 
# Error Tracking (recommended for production)
# Install: composer require sentry/sentry-laravel
# Docs: https://docs.sentry.io/platforms/php/laravel/
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.25
# SENTRY_SEND_DEFAULT_PII=true

DB_CONNECTION=mysql
# DB_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tyro_project       # phpunit.xml uses DB_DATABASE=opspilot_test for test isolation
DB_USERNAME=root
DB_PASSWORD=
# DB_SOCKET=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# DB_FOREIGN_KEYS=true
# DB_ENCRYPT=false
# DB_SSLMODE=prefer
# DB_TRUST_SERVER_CERTIFICATE=false
# MYSQL_ATTR_SSL_CA=

# BROADCAST_CONNECTION=log

CACHE_STORE=redis
# CACHE_PREFIX=
# ASSET_TAG_PREFIX=AST
# MEMCACHED_HOST=127.0.0.1
# MEMCACHED_PORT=11211
# MEMCACHED_USERNAME=
# MEMCACHED_PASSWORD=
# MEMCACHED_PERSISTENT_ID=
# DYNAMODB_CACHE_TABLE=
# DYNAMODB_ENDPOINT=
# DB_CACHE_TABLE=
# DB_CACHE_CONNECTION=
# DB_CACHE_LOCK_TABLE=
# DB_CACHE_LOCK_CONNECTION=

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
# REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_PORT=6379
# REDIS_URL=
# REDIS_DB=0
# REDIS_CACHE_DB=1
# REDIS_PREFIX=
# REDIS_CLUSTER=
# REDIS_PERSISTENT=false
# REDIS_MAX_RETRIES=3
# REDIS_BACKOFF_ALGORITHM=none
# REDIS_BACKOFF_BASE=500
# REDIS_BACKOFF_CAP=5000

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
# SESSION_HTTP_ONLY=true
# SESSION_SAME_SITE=lax
# SESSION_EXPIRE_ON_CLOSE=false
# SESSION_CONNECTION=
# SESSION_STORE=
# SESSION_TABLE=sessions
# SESSION_PARTITIONED_COOKIE=false

# Queue
# WARNING: Use 'sync' for deploy environments without persistent queue workers (cPanel, shared hosting).
#          Use 'database' only if you have a running queue worker (php artisan queue:work).
QUEUE_CONNECTION=sync
# QUEUE_FAILED_DRIVER=database-uuids
# DB_QUEUE_TABLE=
# DB_QUEUE_CONNECTION=
# DB_QUEUE_RETRY_AFTER=90
# REDIS_QUEUE=
# REDIS_QUEUE_CONNECTION=
# REDIS_QUEUE_RETRY_AFTER=90
# SQS_PREFIX=
# SQS_QUEUE=
# SQS_SUFFIX=
# BEANSTALKD_QUEUE=
# BEANSTALKD_QUEUE_HOST=localhost
# BEANSTALKD_QUEUE_RETRY_AFTER=90

# Mail
MAIL_MAILER=log
# MAIL_SCHEME=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@tyro.local"
MAIL_FROM_NAME="OpsPilot"
# MAIL_URL=
# MAIL_EHLO_DOMAIN=
# MAIL_SENDMAIL_PATH=/usr/sbin/sendmail
# MAIL_LOG_CHANNEL=

# Filesystem
FILESYSTEM_DISK=local

# AWS S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# CORS � frontend SPA origin
FRONTEND_URL=http://localhost:3000

